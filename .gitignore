# --- Composer & Dependencies ---
/vendor/

# --- Drupal Configuration & Files ---
/web/sites/*/settings.local.php
/web/sites/*/files/
/web/sites/simpletest

# --- DDEV Specifics ---
# DDEV generates its own .gitignore inside the .ddev folder;
# do not commit the inner .ddev/.gitignore.
.ddev/.gitignore

# If you use DDEV-generated settings files
/web/sites/*/settings.ddev.php

# --- Sensitive Environment Files ---
db.sql.gz

